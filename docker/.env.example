# Example environment for docker/docker-compose.all-in-one.yml
#
# Copy to the directory from which you run Docker Compose (usually the repo root):
#   cp docker/.env.example .env
# Or pass explicitly:
#   docker compose --env-file docker/.env.example -f docker/docker-compose.all-in-one.yml up -d
#
# Do not set variables to empty strings — omit them to use compose defaults.
# See README-docker.md and src/config.rs for full semantics.



# --- host port mappings (container ports are fixed inside the image) ---
POSTGRES_PORT=5433
REDIS_PORT=6379
MEILI_PORT=7700
API_PORT=8282
GUI_PORT=8181

# --- tracing / Rust log filter (not under ELIDUNE_*) ---
RUST_LOG=elidune_server=info,tower_http=info

# --- server ---
ELIDUNE_SERVER__HOST=0.0.0.0
ELIDUNE_SERVER__PORT=8080
ELIDUNE_SERVER__AUTH_RATE_PER_SECOND=4
ELIDUNE_SERVER__AUTH_RATE_BURST=2
ELIDUNE_SERVER__PUBLIC_RATE_PER_SECOND=30
ELIDUNE_SERVER__PUBLIC_RATE_BURST=100
# Optional: JSON array of allowed browser origins (quote the value in .env)
# ELIDUNE_SERVER__CORS_ORIGINS='["https://app.example.com"]'

# --- database (in all-in-one, PostgreSQL listens on localhost inside the container) ---
ELIDUNE_DATABASE__URL=postgres://elidune:elidune@localhost:5432/elidune
ELIDUNE_DATABASE__MAX_CONNECTIONS=10
ELIDUNE_DATABASE__MIN_CONNECTIONS=2

# --- users / JWT (set JWT_SECRET in production) ---
ELIDUNE_USERS__JWT_SECRET=change-this-secret-in-production
ELIDUNE_USERS__JWT_EXPIRATION_HOURS=24

# --- logging ---
ELIDUNE_LOGGING__LEVEL=info
ELIDUNE_LOGGING__FORMAT=pretty
ELIDUNE_LOGGING__OUTPUT=stdout
ELIDUNE_LOGGING__OVERRIDABLE=true
# When ELIDUNE_LOGGING__OUTPUT=file:
# ELIDUNE_LOGGING__FILE_PATH=/var/log/elidune/app.log
# ELIDUNE_LOGGING__FILE_ROTATION=daily

# --- email (uncomment and set when SMTP is available; leave unset to skip) ---
# ELIDUNE_EMAIL__SMTP_HOST=smtp.example.com
ELIDUNE_EMAIL__SMTP_PORT=587
# ELIDUNE_EMAIL__SMTP_USERNAME=
# ELIDUNE_EMAIL__SMTP_PASSWORD=
# ELIDUNE_EMAIL__SMTP_FROM=
# ELIDUNE_EMAIL__SMTP_FROM_NAME=
ELIDUNE_EMAIL__SMTP_USE_TLS=true
ELIDUNE_EMAIL__TEMPLATES_DIR=data/email_templates
ELIDUNE_EMAIL__OVERRIDABLE=true

# --- redis (in-container) ---
ELIDUNE_REDIS__URL=redis://127.0.0.1:6379
ELIDUNE_REDIS__Z3950_CACHE_TTL_SECONDS=604800

# --- loan reminders ---
ELIDUNE_REMINDERS__ENABLED=true
ELIDUNE_REMINDERS__FREQUENCY_DAYS=7
ELIDUNE_REMINDERS__SEND_TIME=09:00
ELIDUNE_REMINDERS__SMTP_THROTTLE_MS=100
ELIDUNE_REMINDERS__OVERRIDABLE=true

# --- audit ---
ELIDUNE_AUDIT__RETENTION_DAYS=365
ELIDUNE_AUDIT__OVERRIDABLE=true

# --- holds ---
ELIDUNE_HOLDS__READY_EXPIRY_DAYS=7
ELIDUNE_HOLDS__OVERRIDABLE=true

# --- meilisearch (MEILI_MASTER_KEY in compose follows ELIDUNE_MEILISEARCH__API_KEY) ---
ELIDUNE_MEILISEARCH__URL=http://127.0.0.1:7700
ELIDUNE_MEILISEARCH__API_KEY=changeme
ELIDUNE_MEILISEARCH__INDEX_NAME=items
